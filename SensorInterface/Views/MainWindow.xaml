<Window x:Class="SensorInterface.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SensorInterface.ViewModels"
        Title="Monitoramento Agrícola" Height="450" Width="800">

	<Window.DataContext>
		<vm:MainViewModel />
	</Window.DataContext>

	<Grid Margin="10">
		<DataGrid ItemsSource="{Binding Historico}" AutoGenerateColumns="False" IsReadOnly="True">
			<DataGrid.Columns>
				<DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
				<DataGridTextColumn Header="Sensor" Binding="{Binding SensorNome}" Width="150"/>
				<DataGridTextColumn Header="Umidade (%)" Binding="{Binding ValorUmidade}" Width="100"/>
				<DataGridTextColumn Header="Status (Lógica API)" Binding="{Binding Status}" Width="*"/>
				<DataGridTextColumn Header="Data Leitura" Binding="{Binding DataLeitura, StringFormat=\{0:dd/MM HH:mm:ss\}}" Width="150"/>
			</DataGrid.Columns>
		</DataGrid>
	</Grid>
</Window>