<Window x:Class="SensorInterface.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SensorInterface.ViewModels"
        Title="Dashboard Agrícola - Umidade" Height="450" Width="800">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Monitoramento de Solo em Tempo Real" FontSize="20" FontWeight="Bold"/>
            <Button Content="Atualizar" Command="{Binding AtualizarCommand}" Margin="20,0,0,0" Width="100"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Historico}" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Sensor" Binding="{Binding SensorNome}" Width="150"/>
                <DataGridTextColumn Header="Umidade (%)" Binding="{Binding ValorUmidade}" Width="100"/>
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                <DataGridTextColumn Header="Data/Hora" Binding="{Binding DataLeitura, StringFormat=\{0:dd/MM HH:mm:ss\}}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>